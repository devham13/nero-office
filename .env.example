# Nero Network Office Page 0.2
# Copy this file to .env or add the same names to Cursor Cloud Secrets / Environment Variables.
# Never commit real values.

# Cursor / automation
CURSOR_API_KEY=
WORKER_POOL_NAME=nero-network-office

# Public site
SITE_BRAND=
SITE_NICHE=
WP_SITE_URL=
WP_ADMIN_URL=
PUBLIC_SITE_URL=
PUBLIC_SITE_HOST=
WP_THEME_SLUG=
WP_CLI_BIN=wp
PHP_BIN=

# WordPress paths
REMOTE_SITE_ROOT=
REMOTE_WP_CONTENT=wp-content
REMOTE_WP_THEMES=wp-content/themes
REMOTE_WP_PLUGINS=wp-content/plugins
SSH_THEME_PATH=wp-content/themes

# SSH / SFTP / FTP
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASSWORD=
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=

# CTA / advertising, optional
PRIMARY_CTA_LABEL=
PRIMARY_CTA_URL=
SECONDARY_CTA_LABEL=
SECONDARY_CTA_URL=
AD_BANNER_URL=
AD_BANNER_IMAGE_URL=
AD_BANNER_ALT=

# Optional notes
PANEL_URL=
NOTES=
